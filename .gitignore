# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables (sensitive data)
.env
.env.local
.env.*.local

# Browser data (large files, platform-specific)
chrome-data/
chrome-data-*/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

