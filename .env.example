# Cấu hình Auto Darkwar Check-in

# ==================== BẮT BUỘC ====================
# Thông tin đăng nhập
DW_EMAIL=your_email_here
DW_PASSWORD=your_password_here

# ==================== TÙY CHỌN ====================
# URL
LOGIN_URL=https://pay.darkwar-survival.com/#/order
CHECKIN_URL=https://pay.darkwar-survival.com/#/order

# Browser settings
HEADLESS=false              # true = chạy ẩn (không mở cửa sổ), false = mở browser nhìn thấy
SLOW_MO=100                 # Delay giữa các action (ms) - giả lập người thật
ACTION_DELAY=1000           # Delay giữa các bước (ms)
LOGIN_DELAY=5000            # Delay sau khi login (ms)
CLOSE_DELAY=20000           # Thời gian chờ trước khi đóng browser (ms) - để xem kết quả
PAGE_TIMEOUT=60000          # Timeout load trang (ms)
ELEMENT_TIMEOUT=15000       # Timeout chờ element (ms)

# Retry settings
MAX_RETRY=3                 # Số lần thử lại nếu thất bại
RETRY_DELAY=5000            # Delay giữa các lần retry (ms)

# Check-in settings
AUTO_CHECKIN=true           # Tự động điểm danh (true/false)
CHECKIN_INTERVAL=86400000   # Khoảng thời gian giữa các lần điểm danh (ms) - mặc định 24h

# Selectors (chỉ cần khi web thay đổi structure)
# CHECKIN_SELECTOR=
# CHECKIN_SUCCESS_SELECTOR=
